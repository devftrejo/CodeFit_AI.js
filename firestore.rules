rules_version = "2";

// All app data lives under users/{uid}. A request is only ever allowed to
// touch its own subtree (request.auth.uid == uid). The Cloud Function uses
// the Admin SDK, which bypasses these rules entirely — so "server-only"
// paths below are enforced by denying client writes here.

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profile doc (displayName, preferredRole, theme, ...) — client-managed.
      allow read, write: if isOwner(uid);

      match /conversations/{conversationId} {
        // Conversations are created by the chat function (Admin SDK). Clients
        // may read and delete their own. Creation stays server-only so role
        // and timestamps stay honest. The one client write allowed is a
        // rename: an update that touches *only* the `title` field (a non-empty
        // string ≤ 200 chars) — clients can't forge role, createdAt, etc.
        allow read, delete: if isOwner(uid);
        allow create: if false;
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["title"])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200;

        match /messages/{messageId} {
          // Messages are written only by the function. Clients read their own
          // and may delete (for "delete conversation" cascade), but cannot
          // forge or edit message content.
          allow read, delete: if isOwner(uid);
          allow create, update: if false;
        }
      }

      match /snippets/{snippetId} {
        // Saved sandbox snippets — fully client-managed.
        allow read, write: if isOwner(uid);
      }
    }
  }
}
