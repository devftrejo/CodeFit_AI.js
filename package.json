{
  "name": "codefit_ai.js",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "${DarkMode} Devs' online AI bootcamp — root workspace for the Vite client and Cloud Functions for Firebase backend.",
  "author": "Fernando Trejo",
  "license": "UNLICENSED",
  "workspaces": [
    "client",
    "functions"
  ],
  "scripts": {
    "dev": "concurrently -n client,emulators -c yellow,cyan \"npm run dev -w client\" \"firebase emulators:start --only functions,auth,firestore\"",
    "build": "npm run build -w client",
    "preview": "npm run preview -w client",
    "emulators": "firebase emulators:start",
    "firebase:deploy": "npm run build && firebase deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "knip": "knip",
    "jscpd": "jscpd"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15.14.0",
    "jscpd": "^5.0.10",
    "knip": "^6.17.1",
    "prettier": "^3.4.2"
  }
}
