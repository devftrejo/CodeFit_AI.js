# Optional override for the chat endpoint (VITE_API_URL). Unset by default:
# dev uses the relative /api/chat (Vite proxy -> Functions emulator), and
# prod uses the Cloud Function URL set in client/.env.production. Set this
# only to point at a custom endpoint (e.g. a remote emulator).
# VITE_API_URL=http://127.0.0.1:5001/codefit-ai-js/us-central1/chat
