# Production build only (loaded by `vite build`, not `vite` dev).
# Firebase Hosting buffers SSE from function rewrites, so in prod the client
# calls the Cloud Function directly (CORS-restricted to our domain) to preserve
# token-by-token streaming. Dev keeps the default /api/chat → Vite proxy →
# Functions emulator (which streams fine), so this is NOT set in dev.
VITE_API_URL=https://us-central1-codefit-ai-js.cloudfunctions.net/chat
